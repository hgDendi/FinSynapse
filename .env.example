# Copy to .env (gitignored). Only FRED key is required for CI;
# all LLM keys stay local-only and are NEVER set in GitHub Secrets.

# --- Data sources ---
FRED_API_KEY=

# --- Local LLM backends (pick one or many; all optional) ---
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Notify channels (optional, both work via webhooks) ---
BARK_DEVICE_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Paths (override only if you move data dir) ---
# FINSYNAPSE_DATA_DIR=./data
