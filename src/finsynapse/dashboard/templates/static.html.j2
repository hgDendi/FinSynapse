<!DOCTYPE html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<title>{{ tx.page_title }} ({{ asof }})</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #FAFAFA;
    --surface: #FFFFFF;
    --border: #E5E7EB;
    --text: #111827;
    --text-muted: #6B7280;
    --accent: #2E86AB;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans CJK SC", "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
  }
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 24px 32px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
  }
  .header-text { flex: 1; min-width: 0; }
  header h1 { margin: 0; font-size: 22px; font-weight: 600; }
  header .meta { color: var(--text-muted); font-size: 13px; margin-top: 4px; }
  .lang-toggle {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 14px;
    color: var(--text);
    text-decoration: none;
    font-size: 13px;
    font-weight: 500;
    transition: all 0.15s ease;
    flex-shrink: 0;
  }
  .lang-toggle:hover { background: #F3F4F6; border-color: #D1D5DB; }
  main { max-width: 1280px; margin: 0 auto; padding: 24px 16px 80px; }
  section { margin-bottom: 32px; }
  section h2 { font-size: 16px; font-weight: 600; margin: 0 0 12px; color: var(--text); }
  .grid { display: grid; gap: 16px; }
  .grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
  .grid.cols-1 { grid-template-columns: 1fr; }
  @media (max-width: 900px) {
    .grid.cols-3 { grid-template-columns: 1fr; }
    header { flex-direction: column; }
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 12px;
  }
  .card.empty {
    color: var(--text-muted);
    font-size: 13px;
    text-align: center;
    padding: 40px 20px;
  }
  .data-quality {
    color: #B45309;
    background: #FEF3C7;
    padding: 4px 8px;
    border-radius: 4px;
    font-size: 12px;
    margin-top: 8px;
    display: inline-block;
  }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th, td { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--border); }
  th { font-weight: 500; color: var(--text-muted); background: #F9FAFB; position: sticky; top: 0; }
  td.num { text-align: right; font-variant-numeric: tabular-nums; }
  footer { color: var(--text-muted); font-size: 12px; text-align: center; padding: 24px; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; }
  .badge-cold { background: rgba(46,134,171,0.15); color: #1E40AF; }
  .badge-mid  { background: rgba(156,163,175,0.20); color: #374151; }
  .badge-hot  { background: rgba(230,57,70,0.15); color: #991B1B; }
</style>
<script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
</head>
<body>
<header>
  <div class="header-text">
    <h1>{{ tx.header_title }}</h1>
    <div class="meta">{{ tx.data_as_of }} <strong>{{ asof }}</strong> · {{ tx.data_meta_suffix }} <code>config/weights.yaml</code></div>
  </div>
  <a href="{{ alt_lang_href }}" class="lang-toggle" title="{{ tx.lang_toggle_hint }}">{{ tx.lang_toggle_label }}</a>
</header>
<main>

<section>
  <h2>{{ tx.section_market_temps }}</h2>
  <div class="grid cols-3">
    {% for market in markets %}
    <div class="card">
      {% if market in gauges %}
        <div id="gauge_{{ market }}"></div>
        <div id="radar_{{ market }}"></div>
        <div id="attrib_{{ market }}"></div>
        {% if data_quality.get(market, 'ok') != 'ok' %}
          <div class="data-quality">{{ tx.data_quality_label }}: {{ data_quality[market] }}</div>
        {% endif %}
      {% else %}
        <div class="empty"><strong>{{ market | upper }}</strong><br>{{ tx.no_data_card }}</div>
      {% endif %}
    </div>
    {% endfor %}
  </div>
</section>

<section>
  <h2>{{ tx.section_long_history }} ({{ history_market | upper }})</h2>
  <div class="card"><div id="time_series"></div></div>
</section>

<section>
  <h2>{{ tx.section_divergence }}</h2>
  <div class="card"><div id="divergence"></div></div>
  {% if divergence_table %}
  <div class="card" style="margin-top:12px; overflow-x:auto;">
    <table>
      <thead><tr><th>{{ tx.th_date }}</th><th>{{ tx.th_pair }}</th><th class="num">{{ tx.th_a_change }}</th><th class="num">{{ tx.th_b_change }}</th><th class="num">{{ tx.th_strength }}</th><th>{{ tx.th_signal }}</th></tr></thead>
      <tbody>
        {% for row in divergence_table %}
        <tr>
          <td>{{ row.date }}</td>
          <td><code>{{ row.pair_name }}</code></td>
          <td class="num">{{ "%+.2f%%" | format(row.a_change * 100) }}</td>
          <td class="num">{{ "%+.2f%%" | format(row.b_change * 100) }}</td>
          <td class="num">{{ "%.4f" | format(row.strength) }}</td>
          <td>{{ row.description }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</section>

<section>
  <h2>{{ tx.section_data_health }}</h2>
  <div class="card">
    {% if not health_summary %}
      <div class="empty">{{ tx.no_health_issues }}</div>
    {% else %}
      <p style="margin:0 0 12px; font-size:13px; color: var(--text-muted);">
        <strong>{{ health_summary.total }}</strong> {{ tx.issues_total }}
        ({{ health_summary.fail }} fail / {{ health_summary.warn }} warn)
      </p>
      <div style="overflow-x:auto;">
      <table>
        <thead><tr><th>{{ tx.th_date }}</th><th>{{ tx.th_indicator }}</th><th>{{ tx.th_rule }}</th><th>{{ tx.th_severity }}</th><th>{{ tx.th_detail }}</th></tr></thead>
        <tbody>
          {% for row in health_table %}
          <tr>
            <td>{{ row.date }}</td>
            <td>{{ row.indicator }}</td>
            <td><code>{{ row.rule }}</code></td>
            <td><span class="badge badge-{{ 'hot' if row.severity == 'fail' else 'mid' }}">{{ row.severity }}</span></td>
            <td><small>{{ row.detail }}</small></td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      </div>
    {% endif %}
  </div>
</section>

</main>
<footer>{{ tx.footer }}</footer>

<script>
  {% for market, fig_json in gauges.items() %}
  Plotly.newPlot('gauge_{{ market }}', {{ fig_json | safe }}.data, {{ fig_json | safe }}.layout, {responsive: true, displayModeBar: false});
  {% endfor %}
  {% for market, fig_json in radars.items() %}
  Plotly.newPlot('radar_{{ market }}', {{ fig_json | safe }}.data, {{ fig_json | safe }}.layout, {responsive: true, displayModeBar: false});
  {% endfor %}
  {% for market, fig_json in attribs.items() %}
  Plotly.newPlot('attrib_{{ market }}', {{ fig_json | safe }}.data, {{ fig_json | safe }}.layout, {responsive: true, displayModeBar: false});
  {% endfor %}
  Plotly.newPlot('time_series', {{ time_series_json | safe }}.data, {{ time_series_json | safe }}.layout, {responsive: true, displayModeBar: false});
  Plotly.newPlot('divergence', {{ divergence_json | safe }}.data, {{ divergence_json | safe }}.layout, {responsive: true, displayModeBar: false});
</script>
</body>
</html>
